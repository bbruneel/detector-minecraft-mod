{
	"schemaVersion": 1,
	"id": "notifier",
	"version": "${version}",
	"name": "Notifier",
	"description": "Shows clear in-game notifications for important gameplay and server events.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://bruneel.org/",
		"sources": "https://github.com/bbruneel/my-first-minecraft-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/notifier/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"org.bruneel.notifier.NotifierMod"
		],
		"client": [
			"org.bruneel.notifier.client.NotifierModClient"
		]
	},
	"mixins": [
		"notifier.mixins.json",
		{
			"config": "notifier.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}