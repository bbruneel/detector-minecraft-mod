{
	"schemaVersion": 1,
	"id": "detector",
	"version": "${version}",
	"name": "Detector",
	"description": "Shows clear in-game notifications for important gameplay and server events.",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://bruneel.org/",
		"sources": "https://github.com/bbruneel/my-first-minecraft-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/detector/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"org.bruneel.detector.DetectorMod"
		],
		"client": [
			"org.bruneel.detector.client.DetectorModClient"
		]
	},
	"mixins": [
		"detector.mixins.json",
		{
			"config": "detector.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
